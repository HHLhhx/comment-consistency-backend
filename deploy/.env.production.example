# =============================================================================
# 生产部署环境变量样例
#
# 用法（在远端服务器上）：
#   cp deploy/.env.production.example .env.production
#   chmod 600 .env.production
#   # 必填项全部填好后：
#   docker compose --env-file .env.production -f docker-compose.yml up -d
#
# 也可直接通过 deploy/remote-deploy.sh 自动生成（CI 推荐路径）。
#
# 标【必填】的不能为空；其余可按需修改。
# =============================================================================

# ============================== 应用 / 入口 ==================================
# GitHub Actions 构建并推送到 GHCR 的镜像
APP_IMAGE=ghcr.io/<github-username>/comment-consistency-backend:latest
APP_PORT=8080
NGINX_HTTP_PORT=80

# 服务器上的持久化卷根目录
DOCKER_VOLUME_DIRECTORY=/data/comment-consistency-backend

# ================================ MySQL ======================================
# 【必填】
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=comment_consistency
MYSQL_USER=comment_user
# 【必填】
MYSQL_PASSWORD=

# ================================ Redis ======================================
# 【必填】
REDIS_PASSWORD=

# ============================ 应用安全密钥 ===================================
# 【必填】JWT 签名密钥；HS256 要求 ≥ 32 字节
# 生成：openssl rand -base64 48
JWT_SECRET=

# 【必填】用户 API Key 加密密钥；必须 64 个十六进制字符（256-bit）
# 生成：openssl rand -hex 32
API_KEY_ENCRYPT_KEY=

# 请求体加解密的 RSA 私钥/公钥（PKCS8 / X.509 base64，单行无换行）
# 私钥若留空，浏览器端将以明文传 password / apiKey
REQUEST_DECRYPT_PRIVATE_KEY=
# 留空则后端从私钥派生公钥提供给前端
REQUEST_ENCRYPT_PUBLIC_KEY=

# 启动时是否触发向量库初始化任务（已初始化过的环境保持 false）
APP_VECTORSTORE_INIT=false

# ================================ AI =========================================
# OpenAI 协议兼容供应商默认 Base URL；用户可在用户设置中按需覆盖
APP_AI_OPENAI_CHAT_BASE_URL=https://api.openai.com

# Embedding 服务（硅基流动）API Key
APP_AI_SILICONFLOW_EMBEDDING_API_KEY=

# ============================== 向量库 =======================================
SPRING_AI_VECTORSTORE_MILVUS_DATABASE_NAME=comment_consistency
SPRING_AI_VECTORSTORE_MILVUS_COLLECTION_NAME=vector_store_test

# ========================== 邮件（注册验证码） ===============================
APP_ALIYUN_ACCESS_KEY_ID=
APP_ALIYUN_ACCESS_KEY_SECRET=
APP_ALIYUN_ACCOUNT_NAME=
APP_ALIYUN_REGION_ID=cn-hangzhou
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# ========================= 监控（Prometheus/Grafana） ========================
# Prometheus 默认绑 127.0.0.1，避免暴露到公网；外网访问请通过 nginx/反代加鉴权
PROMETHEUS_PORT=9090

# Grafana 控制台账号
GRAFANA_ADMIN_USER=admin
# 【必填】生产请改为强密码
GRAFANA_ADMIN_PASSWORD=
GRAFANA_PORT=3000
