# Image built by GitHub Actions and pushed to GHCR
APP_IMAGE=ghcr.io/<github-username>/comment-consistency-backend:latest
APP_PORT=8080

# Persistent volume root on server
DOCKER_VOLUME_DIRECTORY=/data/comment-consistency-backend

# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=comment_consistency
MYSQL_USER=comment_user
MYSQL_PASSWORD=

# Redis
REDIS_PASSWORD=

# Application security
JWT_SECRET=
API_KEY_ENCRYPT_KEY=

# Optional AI runtime settings
APP_AI_OLLAMA_CHAT_BASE_URL=https://ollama.com
APP_AI_OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434
APP_AI_OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b

