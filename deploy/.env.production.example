# Image built by GitHub Actions and pushed to GHCR
APP_IMAGE=ghcr.io/<github-username>/comment-consistency-backend:latest
APP_PORT=8080
NGINX_HTTP_PORT=80

# Persistent volume root on server
DOCKER_VOLUME_DIRECTORY=/data/comment-consistency-backend

# MySQL
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=comment_consistency
MYSQL_USER=comment_user
MYSQL_PASSWORD=

# Redis
REDIS_PASSWORD=

# Application security
JWT_SECRET=
API_KEY_ENCRYPT_KEY=
# Request payload crypto (for encrypted password/api-key transport)
# PKCS8 base64 private key
REQUEST_DECRYPT_PRIVATE_KEY=
# Optional X.509 base64 public key. If empty, backend derives from private key.
REQUEST_ENCRYPT_PUBLIC_KEY=
APP_VECTORSTORE_INIT=false

# Optional AI runtime settings
# cloud
APP_AI_OLLAMA_CHAT_BASE_URL=https://ollama.com
# local
APP_AI_OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434
APP_AI_OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b

# Attu admin UI (default: localhost-only binding on server)
ATTU_BIND_IP=127.0.0.1
ATTU_PORT=8000

SPRING_AI_VECTORSTORE_MILVUS_DATABASE_NAME=comment_consistency
SPRING_AI_VECTORSTORE_MILVUS_COLLECTION_NAME=vector_store_test

