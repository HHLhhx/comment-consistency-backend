# =============================================================================
# 本地开发用环境变量
#
# 用法：
#   cp .env.example .env
#   # 视需要修改下面带【必填】或【请改】的项，其余可保持默认
#
#   # 第一次启动（本机没有镜像，自动从 Dockerfile 构建并打 :local tag）
#   docker compose up -d --build
#
#   # 之后日常启动（直接复用已构建的本地镜像）
#   docker compose up -d
#
#   # 改了源码想重建：
#   docker compose build backend && docker compose up -d
#
# docker compose 会自动加载同目录下的 .env 文件。
# .env 已在 .gitignore 中，不会被提交。
# =============================================================================

# ----------------------------- 应用 / 入口 -----------------------------
# 后端镜像 tag。
#   - 本地开发：保持默认 comment-consistency-backend:local，由 docker-compose
#     的 build 段从 Dockerfile 自动构建，不需要登录任何镜像仓库。
#   - 生产 / CI：覆盖为 ghcr.io/<owner>/<repo>:<sha>，docker compose pull 即可。
APP_IMAGE=comment-consistency-backend:local

# 后端容器对宿主暴露的端口（仅绑 127.0.0.1，前端走 nginx）
APP_PORT=8080

# nginx 对外端口（前端入口）
NGINX_HTTP_PORT=80

# 数据持久化根目录。默认在仓库内 ./volumes/...，便于本地一次性清理
DOCKER_VOLUME_DIRECTORY=.

# ------------------------------ MySQL --------------------------------
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=comment_consistency_db
MYSQL_USER=
MYSQL_PASSWORD=

# ------------------------------ Redis --------------------------------
REDIS_PASSWORD=

# --------------------------- 应用安全密钥 ----------------------------
# JWT 签名密钥；HS256 要求 ≥ 32 字节字符串
# 生成示例：openssl rand -base64 48
JWT_SECRET=

# 用户 API Key 加密密钥；必须是 64 个十六进制字符（256-bit）
# 生成示例：openssl rand -hex 32
API_KEY_ENCRYPT_KEY=

# 可选：浏览器到后端的请求体加解密（PKCS8 / X.509 base64，单行无换行）
# 本地调试若前端未启用加密传输，可全部留空
REQUEST_DECRYPT_PRIVATE_KEY=
REQUEST_ENCRYPT_PUBLIC_KEY=

# 启动时是否触发向量库初始化任务
APP_VECTORSTORE_INIT=false

# ------------------------------- AI ----------------------------------
# OpenAI 协议兼容供应商默认 Base URL；用户可在用户设置中按需覆盖
# 例如 https://api.deepseek.com、https://dashscope.aliyuncs.com/compatible-mode 等
APP_AI_OPENAI_CHAT_BASE_URL=https://api.openai.com

# Embedding 服务（硅基流动）API Key；本地若不跑向量化可留空
APP_AI_SILICONFLOW_EMBEDDING_API_KEY=

# ----------------------------- 向量库 --------------------------------
SPRING_AI_VECTORSTORE_MILVUS_DATABASE_NAME=comment_consistency
SPRING_AI_VECTORSTORE_MILVUS_COLLECTION_NAME=comment_vector_store

# ----------------- 邮件（注册验证码） ----------------
APP_ALIYUN_ACCESS_KEY_ID=
APP_ALIYUN_ACCESS_KEY_SECRET=
APP_ALIYUN_ACCOUNT_NAME=
APP_ALIYUN_REGION_ID=
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=

# ------------------------- 监控（Prometheus/Grafana） ----------------
# Prometheus 仅在宿主 127.0.0.1 监听，避免暴露到公网
PROMETHEUS_PORT=9090

# Grafana 登录账号
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_PORT=3000
